# Reval credentials. Copy to `.env` and fill in the values you need.
# `.env` is gitignored.

# ---------------------------------------------------------------------------
# AWS Bedrock — required for the default benchmark runner (BedrockProvider),
# BedrockJudge, and BedrockEmbeddings. Phase 1 of the unification plan kept
# Bedrock as the only required surface.
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # optional, for temporary credentials

# ---------------------------------------------------------------------------
# Non-Bedrock providers — added in Phase 3. Only required if you benchmark
# a model whose `provider:` in evals/config.yaml is one of these. Tests under
# `evaluations/eval_providers.py` skip per-provider when the matching key is
# missing, so you can set only the keys you need.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=
