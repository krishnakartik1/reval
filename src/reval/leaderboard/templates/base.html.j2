<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{% block title %}REVAL Leaderboard{% endblock %}</title>
<link rel="stylesheet" href="{{ asset_root|default('assets') }}/style.css">
{% block head %}{% endblock %}
</head>
<body>
<header class="site-header">
  <div class="wrap">
    <h1><a href="{{ index_href|default('index.html') }}">REVAL</a> <span class="subtitle">Political bias leaderboard</span></h1>
    <p class="tagline">Fact-aligned evaluation of LLMs across countries and categories.</p>
  </div>
</header>
<main class="wrap">
{% block content %}{% endblock %}
</main>
<footer class="site-footer">
  <div class="wrap">
    <p>Generated by <code>reval leaderboard build</code> · <a href="https://github.com/krishnakartik1/reval">reval on GitHub</a></p>
  </div>
</footer>
{% block scripts %}{% endblock %}
</body>
</html>
