<!doctype html>
<html
  lang="en"
  x-data="{
    theme: localStorage.getItem('reval-theme'),
    isDark() {
      return this.theme === 'dark'
        || (!this.theme && window.matchMedia('(prefers-color-scheme: dark)').matches);
    },
    toggleTheme() {
      const next = this.isDark() ? 'light' : 'dark';
      this.theme = next;
      localStorage.setItem('reval-theme', next);
      document.documentElement.setAttribute('data-theme', next);
    }
  }"
  x-init="if (theme) document.documentElement.setAttribute('data-theme', theme);"
>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="REVAL — fact-aligned political bias leaderboard for large language models, with international coverage.">
  <meta name="theme-color" content="#faf8f3">
  <title>{% block title %}REVAL · Political bias leaderboard{% endblock %}</title>

  <!-- Fonts: Fraunces (variable serif), Inter, JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">

  <!-- Design tokens + custom CSS first, so Tailwind composes on top -->
  <link rel="stylesheet" href="{{ asset_root|default('assets') }}/tokens.css">
  <link rel="stylesheet" href="{{ asset_root|default('assets') }}/style.css">

  <!-- Tailwind Play CDN with inline config that references tokens.css vars -->
  <script>
    window.tailwind = {
      config: {
        darkMode: ['selector', '[data-theme="dark"]'],
        theme: {
          extend: {
            fontFamily: {
              sans:    ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
              display: ['Fraunces', 'Iowan Old Style', 'Georgia', 'serif'],
              mono:    ['JetBrains Mono', 'ui-monospace', 'monospace'],
            },
            colors: {
              paper:    'var(--bg)',
              paper2:   'var(--bg-alt)',
              ink:      'var(--fg)',
              inkdim:   'var(--fg-dim)',
              rule:     'var(--border)',
              rulesoft: 'var(--border-soft)',
              accent:   'var(--accent)',
              accent2:  'var(--accent-2)',
            },
            maxWidth: {
              screen: '1440px',
            },
            letterSpacing: {
              tightest: '-0.025em',
            },
          }
        }
      }
    };
  </script>
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Alpine.js for reactivity, deferred so Alpine waits for the DOM -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.5/dist/cdn.min.js"></script>

  <!-- Lucide icons (SVG, static) -->
  <script defer src="https://cdn.jsdelivr.net/npm/lucide@0.363.0/dist/umd/lucide.min.js"></script>

  <!-- Chart.js for the scatter plot + per-model radar -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <!-- REVAL tiny SVG radar renderer for per-row sparklines -->
  <script src="{{ asset_root|default('assets') }}/radar.js"></script>

  {% block head %}{% endblock %}
</head>

<body>
  <div class="grain" aria-hidden="true"></div>

  <header class="site-header">
    <div class="wrap">
      <h1>
        <a href="{{ index_href|default('index.html') }}" class="flex items-baseline gap-3 no-underline">
          <span>REVAL</span>
          <span class="subtitle hidden sm:inline">Political bias leaderboard</span>
        </a>
      </h1>

      <nav class="flex items-center gap-5">
        <a href="https://github.com/krishnakartik1/reval"
           class="text-[11px] font-medium uppercase tracking-[0.14em] hover:opacity-80 transition-opacity"
           style="color: var(--fg-dim);">
          <span class="hidden sm:inline">GitHub</span>
          <i data-lucide="github" class="sm:hidden w-4 h-4 inline-block"></i>
        </a>
        <button
          @click="toggleTheme()"
          class="h-9 w-9 flex items-center justify-center rounded-full border transition-colors"
          style="border-color: var(--border); background: var(--bg-alt);"
          aria-label="Toggle colour theme"
        >
          <i data-lucide="sun" class="w-4 h-4" x-show="isDark()" style="color: var(--fg);"></i>
          <i data-lucide="moon" class="w-4 h-4" x-show="!isDark()" style="color: var(--fg);"></i>
        </button>
      </nav>
    </div>
  </header>

  <main class="relative z-[2]">
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer no-print">
    <div class="wrap">
      <p>
        Generated by <code class="mono" style="color: var(--fg);">reval leaderboard build</code>
      </p>
      <p>
        <a href="https://github.com/krishnakartik1/reval" class="hover:underline">github.com/krishnakartik1/reval</a>
      </p>
    </div>
  </footer>

  <script>
    // Render Lucide icons on DOMContentLoaded and again after Alpine
    // initialises (so dynamically-bound x-show icons get drawn).
    (function () {
      function draw() {
        if (window.lucide) {
          window.lucide.createIcons();
          return true;
        }
        return false;
      }
      if (!draw()) {
        var tick = setInterval(function () {
          if (draw()) clearInterval(tick);
        }, 50);
      }
      document.addEventListener('alpine:initialized', draw);
      document.addEventListener('alpine:morphed', draw);
    })();
  </script>

  {% block scripts %}{% endblock %}
</body>
</html>
</content>
