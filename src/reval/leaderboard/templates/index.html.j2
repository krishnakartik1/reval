{% extends "base.html.j2" %}
{% set active_tab = 'leaderboard' %}
{% block title %}REVAL · Political bias leaderboard{% endblock %}

{% block content %}
<div
  class="wrap relative z-[2] pt-16 pb-24"
  x-data="leaderboardApp()"
  x-init="init()"
>

  {# ── HERO ─────────────────────────────────────────────────── #}

  <section class="grid grid-cols-1 lg:grid-cols-[1.7fr_1fr] gap-12 lg:gap-20 items-start">
    <div class="reveal reveal-1">
      <div class="eyebrow-accent mb-6 flex items-center gap-2">
        <span class="inline-block w-6 h-px" style="background: var(--accent);"></span>
        <span>Reval benchmark</span>
        <span aria-hidden="true">·</span>
        <span>{{ 2026 }}</span>
      </div>
      <h2 class="display" style="font-size: clamp(44px, 7vw, 96px);">
        Which models<br>
        <span style="color: var(--accent);" class="italic" >argue</span> fairly.
      </h2>
      <p class="mt-8 max-w-xl text-[15px] leading-[1.65]" style="color: var(--fg-dim);">
        A fact-aligned benchmark for evaluating political bias in large
        language models, with international coverage. Scored against empirical
        ground truth — not false symmetry.
      </p>
    </div>

    {# Stat strip — sharp numerals, hairline grid #}
    <div
      class="grid grid-cols-3 self-end reveal reveal-2 border"
      style="border-color: var(--border); background: var(--border);"
    >
      <div class="p-5 flex flex-col gap-2" style="background: var(--bg);">
        <div class="eyebrow">Runs</div>
        <div class="display-md tabular" style="font-size: 40px;" x-text="filteredRows.length"></div>
      </div>
      <div class="p-5 flex flex-col gap-2" style="background: var(--bg);">
        <div class="eyebrow">Providers</div>
        <div class="display-md tabular" style="font-size: 40px;" x-text="providers.length"></div>
      </div>
      <div class="p-5 flex flex-col gap-2" style="background: var(--bg);">
        <div class="eyebrow">Categories</div>
        <div class="display-md tabular" style="font-size: 40px;">{{ categories|length }}</div>
      </div>
    </div>
  </section>

  <hr class="hero-rule reveal reveal-3">

  {# ── FILTER BAR ────────────────────────────────────────────── #}

  <section class="reveal reveal-3 mb-12 flex flex-col gap-6">
    <div class="flex flex-col lg:flex-row lg:items-end gap-6 lg:gap-10">

      {# Search input #}
      <div class="flex flex-col gap-3 lg:min-w-[320px]">
        <label for="reval-search" class="eyebrow">Search models</label>
        <div class="relative">
          <i
            data-lucide="search"
            class="w-4 h-4 absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none"
            style="color: var(--fg-dim);"
          ></i>
          <input
            id="reval-search"
            type="text"
            x-model="search"
            placeholder="e.g. claude, gpt, nova…"
            class="pl-10 pr-4 h-10 w-full text-[13px] rounded-full outline-none transition-colors mono"
            style="background: var(--bg-alt); border: 1px solid var(--border); color: var(--fg);"
          >
        </div>
      </div>

      {# Provider pills #}
      <div class="flex flex-col gap-3 flex-1 min-w-0">
        <div class="flex items-center justify-between">
          <span class="eyebrow">Provider</span>
          <button
            x-show="activeProviders.length"
            @click="activeProviders = []"
            class="text-[10px] uppercase tracking-[0.14em] hover:underline"
            style="color: var(--fg-dim);"
          >clear</button>
        </div>
        <div class="flex flex-wrap gap-2">
          <template x-for="p in providers" :key="p">
            <button
              class="pill"
              :data-active="activeProviders.includes(p)"
              @click="toggleProvider(p)"
            >
              <span x-text="p"></span>
              <span x-show="activeProviders.includes(p)" aria-hidden="true">×</span>
            </button>
          </template>
          <span x-show="providers.length === 0" class="pill pill-ghost">none</span>
        </div>
      </div>

      {# Judge pills #}
      <div class="flex flex-col gap-3 flex-1 min-w-0">
        <div class="flex items-center justify-between">
          <span class="eyebrow flex items-center gap-1">Judge
            <span title="Only one judge can be active at a time. Mixing judges makes direct comparisons misleading — each judge has its own scoring calibration."
                  style="cursor: help; color: var(--fg-dim);">
              <i data-lucide="info" style="width: 13px; height: 13px;"></i>
            </span>
          </span>
          <button
            x-show="activeJudges.length"
            @click="activeJudges = []"
            class="text-[10px] uppercase tracking-[0.14em] hover:underline"
            style="color: var(--fg-dim);"
          >clear</button>
        </div>
        <div class="flex flex-wrap gap-2">
          <template x-for="j in judges" :key="j">
            <button
              class="pill"
              data-testid="judge-pill"
              :data-active="activeJudges.includes(j)"
              @click="toggleJudge(j)"
              :title="j"
            >
              <span class="mono" x-text="shortJudge(j)"></span>
              <span x-show="activeJudges.includes(j)" aria-hidden="true">×</span>
            </button>
          </template>
          <span x-show="judges.length === 0" class="pill pill-ghost">none</span>
        </div>
      </div>

    </div>
  </section>

  {# ── LEADERBOARD TABLE ─────────────────────────────────────── #}

  <section class="reveal reveal-4">
    <div class="flex items-baseline justify-between mb-4">
      <div class="eyebrow">Leaderboard</div>
      <div class="text-[11px] tabular" style="color: var(--fg-dim);">
        showing <span x-text="sortedFilteredRows.length" class="tabular"></span> of <span class="tabular">{{ rows|length }}</span> runs
      </div>
    </div>

    <div class="overflow-x-auto -mx-6 px-6 sm:mx-0 sm:px-0">
      <table class="leader-table">
        <thead>
          <tr>
            <th style="width:60px"></th>
            <th @click="sortBy('model_id')" :class="sortKey==='model_id' ? 'sorted-active':''">
              Model
              <span x-show="sortKey==='model_id'" class="ml-1 text-[9px]" x-text="sortDir==='asc'?'▲':'▼'"></span>
            </th>
            <th @click="sortBy('model_provider')" :class="sortKey==='model_provider' ? 'sorted-active':''" class="hidden md:table-cell">
              Provider
              <span x-show="sortKey==='model_provider'" class="ml-1 text-[9px]" x-text="sortDir==='asc'?'▲':'▼'"></span>
            </th>
            <th data-testid="sort-overall" @click="sortBy('overall_score')" :class="sortKey==='overall_score' ? 'sorted-active':''" class="text-right">
              Overall
              <span x-show="sortKey==='overall_score'" class="ml-1 text-[9px]" x-text="sortDir==='asc'?'▲':'▼'"></span>
            </th>
            {% for category in categories %}
            <th @click="sortBy('{{ category }}')" :class="sortKey==='{{ category }}' ? 'sorted-active':''" class="text-right hidden lg:table-cell">
              {{ category|replace('_',' ') }}
              <span x-show="sortKey==='{{ category }}'" class="ml-1 text-[9px]" x-text="sortDir==='asc'?'▲':'▼'"></span>
            </th>
            {% endfor %}
            <th @click="sortBy('timestamp')" :class="sortKey==='timestamp' ? 'sorted-active':''" class="text-right hidden xl:table-cell">
              Date
              <span x-show="sortKey==='timestamp'" class="ml-1 text-[9px]" x-text="sortDir==='asc'?'▲':'▼'"></span>
            </th>
            <th style="width:32px"></th>
          </tr>
        </thead>
        <tbody>
          <template x-for="row in sortedFilteredRows" :key="row.slug">
            <tr
              data-testid="model-row"
              :data-model-id="row.model_id"
              @click="window.location='models/'+row.slug+'.html'"
            >
              <td>
                <svg
                  class="radar-svg"
                  x-init="renderRadar($el, categoryKeys.map(k => row.category_scores[k] ?? 0))"
                  :aria-label="'Category scores for ' + row.model_id"
                ></svg>
              </td>
              <td>
                <div class="model-id" x-text="row.model_id"></div>
                <span class="slug" x-text="row.slug"></span>
              </td>
              <td class="hidden md:table-cell">
                <span
                  class="provider-chip"
                  :class="'provider-' + row.model_provider"
                  x-text="row.model_provider"
                ></span>
              </td>
              <td class="text-right">
                <span
                  class="score-cell"
                  :class="scoreColor(row.overall_score)"
                  x-text="fmtScore(row.overall_score)"
                ></span>
              </td>
              {% for category in categories %}
              <td class="text-right hidden lg:table-cell">
                <span
                  class="score-cell"
                  :class="scoreColor(row.category_scores['{{ category }}'])"
                  x-text="fmtScore(row.category_scores['{{ category }}'])"
                ></span>
              </td>
              {% endfor %}
              <td class="text-right hidden xl:table-cell text-[11px] tabular" style="color: var(--fg-dim);">
                <span x-text="(row.timestamp || '').slice(0,10)"></span>
              </td>
              <td class="text-right">
                <i data-lucide="arrow-right" class="w-4 h-4 row-arrow inline-block"></i>
              </td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>

    {# No results — only when filters are active but hide nothing #}
    <div
      x-show="allRows.length > 0 && sortedFilteredRows.length === 0"
      class="mt-12 text-center py-16 text-[13px]"
      style="color: var(--fg-dim);"
    >
      No runs match your filters.
      <button @click="resetFilters()" class="ml-2 underline hover:text-[color:var(--accent)]">
        reset
      </button>
    </div>

    {# Empty state — no runs in showcase at all #}
    {% if rows|length == 0 %}
    <div class="mt-12 py-24 text-center">
      <div class="eyebrow mb-4">Empty</div>
      <p class="display-sm text-[28px] mb-6" style="color: var(--fg);">No runs in <code class="mono">showcase/</code> yet.</p>
      <p class="text-[13px] max-w-lg mx-auto" style="color: var(--fg-dim);">
        Run <code class="mono" style="color: var(--fg);">reval run --model &lt;name&gt;</code> and
        copy the result directory into <code class="mono" style="color: var(--fg);">showcase/</code>
        to populate this leaderboard.
      </p>
    </div>
    {% endif %}
  </section>

  {# ── CHART A: Overall Score Ranking ──────────────────────── #}

  {% if rows and rows | selectattr('overall_score') | list %}
  <section class="mt-24 reveal reveal-4">
    <div class="flex items-baseline justify-between mb-4">
      <div class="eyebrow">Overall score ranking</div>
      <div class="text-[11px]" style="color: var(--fg-dim);">
        aggregate score across all ethical categories
      </div>
    </div>
    <div class="scatter-card">
      <div style="height: 320px;">
        <canvas id="overallBarChart"
                role="img"
                style="cursor: pointer;"
                aria-label="Horizontal bar chart ranking models by overall score. See the leaderboard table above for the same data in accessible form."></canvas>
      </div>
    </div>
  </section>
  {% endif %}

  {# ── CHART B: Category Strength Profile ────────────────── #}

  {% if rows|length > 0 %}
  <section class="mt-24 reveal reveal-4">
    <div class="flex items-baseline justify-between mb-4">
      <div class="eyebrow">Category strength profile</div>
      <div class="text-[11px]" style="color: var(--fg-dim);">
        per-category scores for each model
      </div>
    </div>
    <div class="scatter-card">
      <div style="height: 400px;">
        <canvas id="categoryGroupedBar"
                role="img"
                style="cursor: pointer;"
                aria-label="Grouped horizontal bar chart comparing models across ethical categories."></canvas>
      </div>
    </div>
  </section>
  {% endif %}

  {# ── CHART C: Rubric Criterion Heatmap ─────────────────── #}

  {% if rows and rows | selectattr('aggregated_rubric_scores') | list %}
  <section class="mt-24 reveal reveal-4" aria-labelledby="criterion-heatmap-title">
    <div class="flex items-baseline justify-between mb-4">
      <div class="eyebrow" id="criterion-heatmap-title">Rubric criterion fingerprint</div>
      <div class="text-[11px]" style="color: var(--fg-dim);">
        per-criterion scores (0–1, Likert-normalized) · click a row to open the per-model page
      </div>
    </div>
    <div class="heatmap-wrap">
      <div class="criterion-heatmap-grid"
           role="table"
           aria-label="Model-by-criterion score heatmap">
        {# Group header: category spans #}
        <div role="row" class="criterion-heatmap-group-header">
          <div></div>
          <div style="grid-column: span 4;">Figure Treatment</div>
          <div style="grid-column: span 4;">Issue Framing</div>
        </div>
        {# Sub-header: criterion names #}
        <div role="row" class="criterion-heatmap-sub-header">
          <div role="columnheader" class="heatmap-cell-label">Model</div>
          {% for cat, criterion in criterion_columns %}
          <div role="columnheader">{{ criterion | replace("_", " ") | title }}</div>
          {% endfor %}
        </div>
        {# Data rows #}
        <template x-for="row in sortedFilteredRows" :key="row.slug">
          <div role="row"
               class="heatmap-row is-clickable"
               @click="window.location.href = 'models/' + row.slug + '.html'">
            <div role="rowheader"
                 class="heatmap-cell-label"
                 x-text="row.model_id"></div>
            {% for cat, criterion in criterion_columns %}
            <div role="cell"
                 class="heatmap-cell"
                 :class="criterionScoreColor(row.aggregated_rubric_scores && row.aggregated_rubric_scores['{{ cat }}'] && row.aggregated_rubric_scores['{{ cat }}']['{{ criterion }}'])"
                 :title="criterionTooltip('{{ cat }}', '{{ criterion }}', row.aggregated_rubric_scores)"
                 x-text="fmtScore(row.aggregated_rubric_scores && row.aggregated_rubric_scores['{{ cat }}'] && row.aggregated_rubric_scores['{{ cat }}']['{{ criterion }}'])"></div>
            {% endfor %}
          </div>
        </template>
      </div>
    </div>
  </section>
  {% endif %}

  {# ── CHART D: Top-5 Category Radar ─────────────────────── #}

  {% if rows|length > 0 %}
  <section class="mt-24 reveal reveal-4">
    <div class="flex items-baseline justify-between mb-4">
      <div class="eyebrow">Top-5 ethical profile</div>
      <div class="text-[11px]" style="color: var(--fg-dim);">
        category scores for the top 5 models by overall score
      </div>
    </div>
    <div class="scatter-card">
      <div style="height: 380px;">
        <canvas id="radarChart"
                role="img"
                style="cursor: pointer;"
                aria-label="Radar chart overlaying the top 5 models' scores across four ethical categories."></canvas>
      </div>
      <p x-show="sortedFilteredRows.length === 0"
         class="mt-3 text-[11px] leading-[1.6]"
         style="color: var(--fg-dim);">
        No models match the current filters.
      </p>
    </div>
  </section>
  {% endif %}


</div>

{# ── Embedded data for the Alpine component ────────────────── #}
<script id="leaderboard-data" type="application/json">{{ leaderboard_data | tojson | safe }}</script>
<script id="rubric-descriptions" type="application/json">{{ rubric_descriptions | tojson | safe }}</script>
<script id="category-descriptions" type="application/json">{{ category_descriptions | tojson | safe }}</script>

<script>
  function leaderboardApp() {
    var data;
    try {
      data = JSON.parse(document.getElementById('leaderboard-data').textContent);
    } catch (e) {
      data = { rows: [], categories: [] };
    }

    return {
      allRows: data.rows || [],
      categoryKeys: data.categories || [],

      search: '',
      sortKey: 'overall_score',
      sortDir: 'desc',
      activeProviders: [],
      activeJudges: [],

      _rubricDescriptions: {},
      _categoryDescriptions: {},

      init() {
        try {
          this._rubricDescriptions = JSON.parse(
            document.getElementById('rubric-descriptions').textContent
          );
        } catch (e) { this._rubricDescriptions = {}; }
        try {
          this._categoryDescriptions = JSON.parse(
            document.getElementById('category-descriptions').textContent
          );
        } catch (e) { this._categoryDescriptions = {}; }

        this.$nextTick(() => {
          this.renderAllCharts();
          if (window.lucide) lucide.createIcons();
        });

        var self = this;
        ['search', 'sortKey', 'sortDir'].forEach(function (prop) {
          self.$watch(prop, function () {
            self.$nextTick(function () { self.renderAllCharts(); });
          });
        });
        this.$watch('activeProviders', function () {
          self.$nextTick(function () { self.renderAllCharts(); });
        });
        this.$watch('activeJudges', function () {
          self.$nextTick(function () { self.renderAllCharts(); });
        });
      },

      get providers() {
        var set = {};
        this.allRows.forEach(r => { if (r.model_provider) set[r.model_provider] = true; });
        return Object.keys(set).sort();
      },

      get judges() {
        var set = {};
        this.allRows.forEach(r => { if (r.judge_model_id) set[r.judge_model_id] = true; });
        return Object.keys(set).sort();
      },

      shortJudge(id) {
        if (!id) return '';
        // Split on `/` only: splitting on `.` or `:` mangles Bedrock IDs (`amazon.nova-lite-v1:0` -> `"0"`).
        var parts = id.split('/');
        return parts[parts.length - 1] || id;
      },

      toggleProvider(p) {
        var idx = this.activeProviders.indexOf(p);
        if (idx >= 0) this.activeProviders.splice(idx, 1);
        else this.activeProviders.push(p);
      },

      toggleJudge(j) {
        // Single-select: only one judge at a time. Reassignment (not
        // splice/push) so Alpine's $watch fires reliably.
        if (this.activeJudges.length === 1 && this.activeJudges[0] === j) {
          this.activeJudges = [];
        } else {
          this.activeJudges = [j];
        }
      },

      resetFilters() {
        this.search = '';
        this.activeProviders = [];
        this.activeJudges = [];
      },

      matchesFilters(row) {
        if (this.search) {
          var q = this.search.toLowerCase();
          var hay = (row.model_id || '').toLowerCase();
          if (hay.indexOf(q) === -1) return false;
        }
        if (this.activeProviders.length && this.activeProviders.indexOf(row.model_provider) === -1) {
          return false;
        }
        if (this.activeJudges.length && this.activeJudges.indexOf(row.judge_model_id) === -1) {
          return false;
        }
        return true;
      },

      get filteredRows() {
        return this.allRows.filter(r => this.matchesFilters(r));
      },

      get sortedFilteredRows() {
        var key = this.sortKey;
        var dir = this.sortDir === 'asc' ? 1 : -1;
        var cats = this.categoryKeys;
        return this.filteredRows.slice().sort(function (a, b) {
          var av, bv;
          if (cats.indexOf(key) >= 0) {
            av = a.category_scores[key];
            bv = b.category_scores[key];
          } else {
            av = a[key];
            bv = b[key];
          }
          if (av == null && bv == null) return 0;
          if (av == null) return 1;
          if (bv == null) return -1;
          if (typeof av === 'number' && typeof bv === 'number') return (av - bv) * dir;
          return String(av).localeCompare(String(bv)) * dir;
        });
      },

      sortBy(key) {
        if (this.sortKey === key) {
          this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          this.sortKey = key;
          this.sortDir = 'desc';
        }
      },

      scoreColor(score) {
        if (score == null) return 'score-none';
        if (score >= 0.85) return 'score-high';
        if (score >= 0.70) return 'score-mid';
        return 'score-low';
      },

      fmtScore(score) {
        if (score == null) return '—';
        return Number(score).toFixed(3);
      },

      criterionScoreColor(score) {
        if (score == null) return 'score-none';
        if (score >= 0.875) return 'score-high';
        if (score >= 0.625) return 'score-mid';
        return 'score-low';
      },

      criterionTooltip(cat, criterion, rubricScores) {
        var score = rubricScores && rubricScores[cat] && rubricScores[cat][criterion];
        var display = criterion.replace(/_/g, ' ');
        var desc = this._rubricDescriptions[cat] && this._rubricDescriptions[cat][criterion];
        var parts = display + ': ' + this.fmtScore(score);
        if (desc) parts += ' — ' + desc;
        return parts;
      },

      _isDark() {
        return document.documentElement.getAttribute('data-theme') === 'dark'
          || (!document.documentElement.getAttribute('data-theme')
              && window.matchMedia('(prefers-color-scheme: dark)').matches);
      },

      _chartColors() {
        var isDark = this._isDark();
        return {
          accent:    isDark ? '#d47a47' : '#a85c32',
          axisColor: isDark ? 'rgba(143,138,126,0.8)' : 'rgba(107,102,96,0.85)',
          gridColor: isDark ? 'rgba(42,38,32,0.6)'   : 'rgba(217,211,195,0.5)',
          labelColor: isDark ? '#d4cfc0' : '#3d3d3d',
          tooltipBg: isDark ? '#17140f' : '#faf8f3',
          tooltipTitle: isDark ? '#f5f0e3' : '#1a1a1a',
          tooltipBody: isDark ? '#d4cfc0' : '#3d3d3d',
        };
      },

      _categoryPalette() {
        var isDark = this._isDark();
        return {
          figure_treatment:     isDark ? '#d47a47'              : '#a85c32',
          issue_framing:        isDark ? '#6ba3be'              : '#3a7a96',
          policy_attribution:   isDark ? '#8fb573'              : '#5e8a42',
          argumentation_parity: isDark ? '#c4a0d4'              : '#8a5ea0',
        };
      },

      renderAllCharts() {
        if (!window.Chart) return;
        try { this.renderOverallBar(); }
        catch (e) { console.error('renderOverallBar failed:', e); }
        try { this.renderCategoryGroupedBar(); }
        catch (e) { console.error('renderCategoryGroupedBar failed:', e); }
        try { this.renderTop5Radar(); }
        catch (e) { console.error('renderTop5Radar failed:', e); }
      },

      renderOverallBar() {
        var canvas = document.getElementById('overallBarChart');
        if (!canvas) return;
        var prev = Chart.getChart(canvas);
        if (prev) prev.destroy();

        var c = this._chartColors();
        var rows = this.sortedFilteredRows
          .filter(function (r) { return r.overall_score != null; })
          .slice()
          .sort(function (a, b) { return a.overall_score - b.overall_score; });

        new Chart(canvas.getContext('2d'), {
          type: 'bar',
          data: {
            labels: rows.map(function (r) { return r.model_id; }),
            datasets: [{
              data: rows.map(function (r) { return r.overall_score; }),
              backgroundColor: c.accent + 'cc',
              borderColor: c.accent,
              borderWidth: 1,
              borderRadius: 3,
            }]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            layout: { padding: { left: 8, right: 8 } },
            onClick: function (evt, elements) {
              if (!elements.length) return;
              var row = rows[elements[0].index];
              if (row && row.slug) window.location.href = 'models/' + row.slug + '.html';
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: c.tooltipBg,
                titleColor: c.tooltipTitle,
                bodyColor: c.tooltipBody,
                borderColor: c.accent,
                borderWidth: 1,
                padding: 10,
                displayColors: false,
                titleFont: { family: 'Inter, sans-serif', size: 11, weight: '600' },
                bodyFont: { family: 'JetBrains Mono, monospace', size: 11 },
                callbacks: {
                  label: function (ctx) { return 'score: ' + ctx.raw.toFixed(3); },
                }
              }
            },
            scales: {
              x: {
                min: 0, max: 1,
                ticks: {
                  color: c.axisColor,
                  font: { family: 'JetBrains Mono, monospace', size: 10 },
                  stepSize: 0.25,
                },
                grid: { color: c.gridColor },
              },
              y: {
                ticks: {
                  color: c.labelColor,
                  font: { family: 'Inter, sans-serif', size: 11, weight: '500' },
                  autoSkip: false,
                },
                grid: { display: false },
              }
            }
          }
        });
      },

      renderCategoryGroupedBar() {
        var canvas = document.getElementById('categoryGroupedBar');
        if (!canvas) return;
        var prev = Chart.getChart(canvas);
        if (prev) prev.destroy();

        var c = this._chartColors();
        var palette = this._categoryPalette();
        var catDescs = this._categoryDescriptions;
        var rows = this.sortedFilteredRows;
        var labels = rows.map(function (r) { return r.model_id; });
        var cats = this.categoryKeys;

        var datasets = cats.map(function (cat) {
          return {
            label: cat.replace(/_/g, ' '),
            data: rows.map(function (r) { return r.category_scores[cat] ?? null; }),
            backgroundColor: (palette[cat] || c.accent) + 'aa',
            borderColor: palette[cat] || c.accent,
            borderWidth: 1,
            borderRadius: 2,
          };
        });

        new Chart(canvas.getContext('2d'), {
          type: 'bar',
          data: { labels: labels, datasets: datasets },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            layout: { padding: { left: 8, right: 8 } },
            onClick: function (evt, elements) {
              if (!elements.length) return;
              var row = rows[elements[0].index];
              if (row && row.slug) window.location.href = 'models/' + row.slug + '.html';
            },
            plugins: {
              legend: {
                display: true,
                position: 'top',
                labels: {
                  color: c.labelColor,
                  font: { family: 'Inter, sans-serif', size: 10 },
                  boxWidth: 12,
                  padding: 12,
                }
              },
              tooltip: {
                backgroundColor: c.tooltipBg,
                titleColor: c.tooltipTitle,
                bodyColor: c.tooltipBody,
                borderColor: c.accent,
                borderWidth: 1,
                padding: 10,
                displayColors: false,
                titleFont: { family: 'Inter, sans-serif', size: 11, weight: '600' },
                bodyFont: { family: 'JetBrains Mono, monospace', size: 11 },
                callbacks: {
                  title: function (items) {
                    var raw = items[0];
                    return labels[raw.dataIndex] + ' · ' + raw.dataset.label;
                  },
                  label: function (ctx) {
                    return 'score: ' + (ctx.raw != null ? ctx.raw.toFixed(3) : '—');
                  },
                  afterBody: function (items) {
                    var catKey = cats[items[0].datasetIndex];
                    var desc = catDescs[catKey];
                    return desc ? [desc] : [];
                  }
                }
              }
            },
            scales: {
              x: {
                min: 0, max: 1,
                ticks: {
                  color: c.axisColor,
                  font: { family: 'JetBrains Mono, monospace', size: 10 },
                  stepSize: 0.25,
                },
                grid: { color: c.gridColor },
              },
              y: {
                ticks: {
                  color: c.labelColor,
                  font: { family: 'Inter, sans-serif', size: 11, weight: '500' },
                  autoSkip: false,
                },
                grid: { display: false },
              }
            }
          }
        });
      },

      renderTop5Radar() {
        var canvas = document.getElementById('radarChart');
        if (!canvas) return;
        var prev = Chart.getChart(canvas);
        if (prev) prev.destroy();

        var c = this._chartColors();
        var isDark = this._isDark();
        var catDescs = this._categoryDescriptions;
        var cats = this.categoryKeys;

        var top5 = this.sortedFilteredRows
          .filter(function (r) { return r.overall_score != null; })
          .slice()
          .sort(function (a, b) {
            if (b.overall_score !== a.overall_score) return b.overall_score - a.overall_score;
            return (a.model_id || '').localeCompare(b.model_id || '');
          })
          .slice(0, 5);

        if (top5.length === 0) return;

        var radarPalette = isDark
          ? ['#d47a47', '#6ba3be', '#8fb573', '#c4a0d4', '#e0c87a']
          : ['#a85c32', '#3a7a96', '#5e8a42', '#8a5ea0', '#b89a2e'];

        var datasets = top5.map(function (row, i) {
          var color = radarPalette[i % radarPalette.length];
          return {
            label: row.model_id,
            data: cats.map(function (cat) { return row.category_scores[cat] ?? 0; }),
            backgroundColor: color + '59',
            borderColor: color,
            borderWidth: 1.5,
            pointRadius: 3,
            pointBackgroundColor: color,
          };
        });

        new Chart(canvas.getContext('2d'), {
          type: 'radar',
          data: {
            labels: cats.map(function (cat) { return cat.replace(/_/g, ' '); }),
            datasets: datasets,
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            onClick: function (evt, elements) {
              if (!elements.length) return;
              var row = top5[elements[0].datasetIndex];
              if (row && row.slug) window.location.href = 'models/' + row.slug + '.html';
            },
            plugins: {
              legend: {
                display: true,
                position: 'right',
                labels: {
                  color: c.labelColor,
                  font: { family: 'Inter, sans-serif', size: 10 },
                  boxWidth: 12,
                  padding: 10,
                }
              },
              tooltip: {
                backgroundColor: c.tooltipBg,
                titleColor: c.tooltipTitle,
                bodyColor: c.tooltipBody,
                borderColor: c.accent,
                borderWidth: 1,
                padding: 10,
                displayColors: false,
                titleFont: { family: 'Inter, sans-serif', size: 11, weight: '600' },
                bodyFont: { family: 'JetBrains Mono, monospace', size: 11 },
                callbacks: {
                  title: function (items) {
                    return items[0].dataset.label + ' · ' + cats[items[0].dataIndex].replace(/_/g, ' ');
                  },
                  label: function (ctx) {
                    return 'score: ' + ctx.raw.toFixed(3);
                  },
                  afterBody: function (items) {
                    var catKey = cats[items[0].dataIndex];
                    var desc = catDescs[catKey];
                    return desc ? [desc] : [];
                  }
                }
              }
            },
            scales: {
              r: {
                min: 0, max: 1,
                ticks: {
                  color: c.axisColor,
                  font: { family: 'JetBrains Mono, monospace', size: 9 },
                  stepSize: 0.25,
                  backdropColor: 'transparent',
                },
                pointLabels: {
                  color: c.labelColor,
                  font: { family: 'Inter, sans-serif', size: 11, weight: '500' },
                },
                grid: { color: c.gridColor },
                angleLines: { color: c.gridColor },
              }
            }
          }
        });
      }
    };
  }
</script>
{% endblock %}
